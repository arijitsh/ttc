+void SkolemFC::SklFC::apply_default_config()
+{
+  // Mirror the default configuration used by the skolemfc command line tool so
+  // that an embedding application can drive a count after only adding the CNF,
+  // forall and exists variables. The ordering of these setters is
+  // interdependent and must match main.cpp.
+  set_noguarntee_mode(false);
+  set_oracles(/*use_unisamp=*/true, /*exact_f=*/true, /*exact_g=*/false);
+  set_g_counter_parameters(/*epsilon_g=*/0.08, /*delta_g=*/0.08);
+  check_ready();
+  set_num_threads(1);
+  set_parameters();
+  set_ignore_unsat(/*ignore_unsat=*/true);
+  set_static_samp(/*static_samp=*/true);
+  set_dklr_parameters(
+      /*epsilon_weightage_fc=*/0.6, /*delta_weightage_fc=*/0.5,
+      /*max_error_logcounter=*/0.1);
+}
+
 const char* SkolemFC::SklFC::get_version_info()
 {
   return SkolemFCInt::get_version_sha1();
